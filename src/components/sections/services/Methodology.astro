---
import { getTranslations } from "../../../i18n/ui";

const { lang = "es" } = Astro.props;
const t = getTranslations(lang);
const { services } = t;
---

<section class="section">
  <div class="container">
    <h2 class="display section-title text-4xl mb-8" data-gsap="fade-up">
      {services.methodologyTitle}
    </h2>

    <div class="methodology-container">
      {
        services.methodologySteps.map((step, index) => (
          <div class="methodology-step" data-gsap="fade-up">
            <div class="step-number mono text-accent">{step.step}</div>
            <div class="step-content">
              <h3 class="display step-name text-2xl">{step.name}</h3>
              <p class="step-desc text-secondary">{step.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-title {
    text-align: right;
  }

  .mb-8 {
    margin-bottom: 4rem;
  }

  .methodology-container {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .methodology-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--line);
    align-items: center;
  }

  .step-number {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.8;
  }

  .step-name {
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 1.1rem;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .methodology-step {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2.5rem 0;
    }
    .section-title {
      text-align: left;
    }
  }
</style>
