---
import { getTranslations } from "../../../i18n/ui";

const { lang = "es" } = Astro.props;
const t = getTranslations(lang);
const { services } = t;
---

<section class="section seo-section">
  <!-- Efectos de fondo oscuro + resplandor -->
  <div class="bg-glow"></div>
  <div class="bg-orb"></div>

  <div class="container seo-container">
    <div class="seo-grid">
      <!-- Columna Izquierda: Tarjeta Oscura (Elegante) -->
      <div class="dark-card" data-gsap="fade-up">
        <h2 class="display dark-card-title text-2xl text-primary mb-4">
          {services.growthTitle}
        </h2>

        <p class="mono dark-card-highlight text-base text-secondary">
          {services.growthHighlight}
        </p>

        <div class="dark-card-list">
          {
            services.growthParagraphs.map((paragraph: string) => (
              <div class="list-item">
                <div class="list-icon text-accent">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                </div>
                <p class="list-text">{paragraph}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Columna Derecha: The Hook Text -->
      <div class="hook-column" data-gsap="fade-in">
        <h3 class="display hook-title text-3xl text-primary">
          {
            lang === "es"
              ? "El 85% de tus prospectos te están buscando... ¿Encontrarán a tu competencia?"
              : "85% of your prospects are searching... Will they find your competition?"
          }
        </h3>

        <p class="mono hook-desc">
          {
            lang === "es"
              ? "Si hoy no te encuentran o tu página no genera confianza, probablemente están contactando a otra empresa. Tu sitio web debe ayudarte a vender, no solo verse bonito."
              : "If they can't find you today or your page doesn't build trust, they are probably contacting another company. Your website should help you sell, not just look pretty."
          }
        </p>

        <div class="hook-cta">
          <a
            href={lang === "es" ? "/contacto" : "/en/contacto"}
            class="mono btn-audit"
          >
            {lang === "es" ? "Auditar mi plataforma" : "Audit my platform"}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .seo-section {
    position: relative;
    background-color: var(--bg-primary);
    padding-top: 4rem;
    padding-bottom: 4rem;
    min-height: auto;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .seo-section {
      padding-top: 8rem;
      padding-bottom: 8rem;
      min-height: 80vh;
    }
  }

  /* Efectos de fondo */
  .bg-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 70%;
    height: 100%;
    background: linear-gradient(225deg, var(--accent) 0%, transparent 70%);
    opacity: 0.15;
    pointer-events: none;
  }

  .bg-orb {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 50vw;
    height: 50vw;
    border-radius: 50%;
    background-color: var(--accent);
    filter: blur(150px);
    opacity: 0.2;
    pointer-events: none;
  }

  .seo-container {
    position: relative;
    z-index: 10;
  }

  .seo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .seo-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  /* Tarjeta Oscura (Izquierda) */
  .dark-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--line-light);
    border-radius: 1.5rem;
    padding: 1.5rem;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 768px) {
    .dark-card {
      padding: 3rem;
    }
  }

  .dark-card-title {
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .dark-card-highlight {
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .dark-card-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .list-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .list-icon {
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .list-text {
    font-size: 1.1rem;
    color: var(--text-primary);
    line-height: 1.6;
  }

  /* Columna Derecha (Hook) */
  .hook-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .hook-column {
      padding-left: 2rem;
    }
  }

  .hook-title {
    line-height: 1.1;
    text-transform: uppercase;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }

  .hook-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin-top: 1rem;
  }

  .hook-cta {
    margin-top: 2rem;
  }

  .btn-audit {
    display: inline-block;
    padding: 1.2rem 2.5rem;
    background-color: #ffffff;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: bold;
    text-decoration: none;
    border-radius: 0.5rem;
  }

  .btn-audit:hover {
    background-color: var(--accent);
    color: var(--bg-primary);
    transform: translateY(-3px);
  }
</style>
