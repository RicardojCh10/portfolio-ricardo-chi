---
/**
 * ============================================================
 *  🏝️ ISLA: HeaderScroll.astro
 * ============================================================
 * 
 * ¿POR QUÉ ES UNA ISLA?
 * ----------------------
 * Detecta la posición de scroll para:
 * - Cambiar el fondo del header (transparente → opaco)
 * - Resaltar el link de navegación de la sección actual
 * 
 * Solo envía ~30 líneas de JS al navegador.
 * ============================================================
 */
---

<script>
  const header = document.getElementById('main-header');
  const navLinks = document.querySelectorAll('.nav__link[href^="#"]');
  const sections = document.querySelectorAll('section[id]');

  // Cambiar estilo del header al hacer scroll
  function updateHeader() {
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.add('header--scrolled');
    } else {
      header.classList.remove('header--scrolled');
    }
  }

  // Resaltar link de la sección actual
  function updateActiveLink() {
    const scrollPos = window.scrollY + 100;

    sections.forEach((section) => {
      const sectionElement = section as HTMLElement;
      const top = sectionElement.offsetTop;
      const height = sectionElement.offsetHeight;
      const id = sectionElement.getAttribute('id');

      if (scrollPos >= top && scrollPos < top + height) {
        navLinks.forEach((link) => {
          link.classList.remove('nav__link--active');
          if (link.getAttribute('href') === `#${id}`) {
            link.classList.add('nav__link--active');
          }
        });
      }
    });
  }

  window.addEventListener('scroll', () => {
    updateHeader();
    updateActiveLink();
  }, { passive: true });

  // Ejecutar al cargar
  updateHeader();
  updateActiveLink();
</script>
