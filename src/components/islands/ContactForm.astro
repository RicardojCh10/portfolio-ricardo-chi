---
---
<form id="contact-form" class="form" novalidate>
  <div class="form-row">
    <div class="form-group">
      <label class="form-label" for="nombre">Nombre <span>(obligatorio)</span></label>
      <input type="text" id="nombre" name="nombre" class="form-input" required />
    </div>
    <div class="form-group">
      <label class="form-label" for="apellido">Apellido <span>(obligatorio)</span></label>
      <input type="text" id="apellido" name="apellido" class="form-input" required />
    </div>
  </div>

  <div class="form-group">
    <label class="form-label" for="email">Correo electrónico <span>(obligatorio)</span></label>
    <input type="email" id="email" name="email" class="form-input" required />
  </div>

  <div class="form-group">
    <label class="form-checkbox">
      <input type="checkbox" name="newsletter" />
      <span>Regístrate para recibir noticias y actualizaciones</span>
    </label>
  </div>

  <div class="form-group" style="margin-top: 2rem;">
    <label class="form-label" for="mensaje">Mensaje <span>(obligatorio)</span></label>
    <textarea id="mensaje" name="mensaje" class="form-textarea" required></textarea>
  </div>

  <div class="form-submit" style="margin-top: 2.5rem;">
    <button type="submit" class="btn btn--primary" id="submit-btn">ENVIAR</button>
  </div>
  
  <div id="form-status" style="margin-top: 1rem; font-size: 0.85rem;"></div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';

    // Simulate API call
    setTimeout(() => {
      status.textContent = 'Mensaje enviado correctamente. Nos pondremos en contacto pronto.';
      status.style.color = '#22c55e';
      form.reset();
      submitBtn.disabled = false;
      submitBtn.textContent = 'ENVIAR';
    }, 1500);
  });
</script>
