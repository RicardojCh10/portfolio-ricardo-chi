---
const { lang = 'es' } = Astro.props;
---
<div id="page-transition" class="page-transition" aria-hidden="true" transition:persist="page-transition">
  <div class="transition-text mono text-accent">{lang === 'es' ? 'CARGANDO...' : 'LOADING...'}</div>
</div>

<script>
  import { gsap } from 'gsap';

  // Interceptar la navegación de Astro
  document.addEventListener('astro:before-preparation', (e: any) => {
    const originalLoader = e.loader;
    const transitionEl = document.getElementById('page-transition');
    
    e.loader = async () => {
      // Bloquear scroll de la página vieja durante la transición de salida
      document.body.style.overflow = 'hidden';

      // 1. Mostrar pantalla de carga rápido sin delay artificial
      gsap.set(transitionEl, { display: 'flex' });
      await gsap.to(transitionEl, { yPercent: 0, duration: 0.3, ease: "power2.inOut" });

      // 2. Cargar la página real (DOM swap) velozmente
      await originalLoader();
    };
  });

  // Limpieza vital del body ANTES de pintar la nueva vista
  document.addEventListener('astro:after-swap', () => {
    document.body.style.overflow = '';
  });

  document.addEventListener('astro:page-load', () => {
    const transitionEl = document.getElementById('page-transition');
    
    // Por si acaso quedó atascado
    document.body.style.overflow = ''; 

    // 3. Ocultar pantalla de carga al terminar
    gsap.to(transitionEl, { 
      yPercent: -100, 
      duration: 0.6, 
      ease: "expo.inOut",
      onComplete: () => {
        gsap.set(transitionEl, { display: 'none', yPercent: 100 });
      }
    });
  });
</script>

<style>
  .page-transition {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100vh;
    background-color: var(--bg-secondary);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transform: translateY(100%);
    will-change: transform;
  }
  .transition-text {
    font-size: 1.5rem;
    letter-spacing: 0.2em;
    animation: blink 1s infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>
